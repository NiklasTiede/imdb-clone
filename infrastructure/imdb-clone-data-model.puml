@startuml

!pragma layout smetana

title IMDB Clone Conceptual Data Model

left to right direction
skinparam shadowing false
skinparam linetype ortho
hide circle

skinparam rectangle {
  BorderColor #5a6f89
  RoundCorner 8
}

rectangle "Account" as account #b8d5fc
rectangle "Movie" as movie #b8d5fc

rectangle "Rating\none score per account/movie" as rating #c8eafa
rectangle "WatchedMovie\nmovies saved by users" as watched_movie #c8eafa
rectangle "Comment\nmovie discussion entries" as comment #c8eafa

rectangle "AccountRoles\naccount-to-role join" as account_roles #d7edf7
rectangle "Role\nROLE_USER, ROLE_ADMIN" as role #d7edf7
rectangle "VerificationToken\nemail confirmation / password reset" as verification_token #d7edf7

account ||--o{ rating
rating }o--|| movie

account ||--o{ watched_movie
watched_movie }o--|| movie

account ||--o{ comment
comment }o--|| movie

account ||--o{ account_roles
account_roles }o--|| role

account ||--o{ verification_token

note bottom of movie
  Movie.id stores the IMDb title id
  without the "tt" prefix.
end note

note bottom of rating
  rating, watched_movie, and comment
  are the main user/movie interaction tables.
end note

@enduml
