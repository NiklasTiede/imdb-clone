{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install chromium",
    "e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "format": "yarn prettier --write .",
    "checkUpdates": "ncu",
    "updateOpenApiSpec": "curl http://localhost:8080/v3/api-docs.yaml > ./src/client/imdb-clone-backend.yaml",
    "build:moviesGen": "openapi-generator-cli generate -i ./src/client/imdb-clone-backend.yaml -g typescript-axios -o ./src/client/movies/generator-output/"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@hookform/resolvers": "5.2.2",
    "@mui/icons-material": "^5.14.3",
    "@mui/material": "^5.14.3",
    "@mui/x-date-pickers": "^5.0.20",
    "@reduxjs/toolkit": "2.11.2",
    "@rematch/core": "^2.2.0",
    "immer": "^10.0.2",
    "jwt-decode": "^3.1.2",
    "moment": "2.30.1",
    "notistack": "^3.0.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.75.0",
    "react-image-crop": "^9.1.1",
    "react-redux": "9.2.0",
    "react-router-dom": "6.30.3",
    "redux": "5.0.1",
    "web-vitals": "^3.4.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@openapitools/openapi-generator-cli": "^2.7.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.4.9",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-testing-library": "7.16.2",
    "globals": "17.6.0",
    "jsdom": "^27.3.0",
    "prettier": "^3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vite": "^8.0.11",
    "vitest": "^4.0.7"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
